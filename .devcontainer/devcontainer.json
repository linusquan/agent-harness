{
  "name": "Agent Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // Mount the project directory into the container
  "workspaceFolder": "/src",
  "workspaceMount": "source=${localWorkspaceFolder},target=/src,type=bind,consistency=cached",

  // Add Node.js 22 via feature (keeps the image lean)
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "22" }
  },

  // Forward common dev ports
  "forwardPorts": [5173, 3001],
  "portsAttributes": {
    "5173": { "label": "Vite Dev Server", "onAutoForward": "notify" }
  },

  // VS Code extensions useful for Node + Python + React development
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "python.defaultInterpreterPath": "/usr/local/bin/python3"
      }
    }
  },

  // Claude Code MCP configuration pointing to the host-side Playwright MCP server.
  // Before opening this devcontainer, start the host server:
  //   npx @playwright/mcp --port 3001 --host 0.0.0.0 --allowed-hosts '*'
  "mounts": [
    // Pass Docker socket in so the container can build/run sibling containers if needed
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],

  "remoteEnv": {
    // Lets tools inside the container reach the host machine
    "PLAYWRIGHT_MCP_URL": "http://host.docker.internal:3001/sse"
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "remoteUser": "vscode"
}
